<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base splash theme used on API 24-30 through androidx.core:splashscreen compatibility.
        On these versions the library reads the non-namespaced attrs below and then switches
        to Theme.UnitWise.App via postSplashScreenTheme.
    -->
    <style name="Theme.UnitWise" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.UnitWise.App</item>
    </style>

    <!--
        Normal app theme applied after the splash is dismissed.
        Keep this theme without ActionBar so older devices do not show an unexpected toolbar.
    -->
    <style name="Theme.UnitWise.App" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
